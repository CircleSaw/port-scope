<Window x:Class="PortScope.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:PortScope"
        mc:Ignorable="d"
        Title="PortScope"
        Height="900" Width="1350"
        MinHeight="700" MinWidth="1100"
        WindowStartupLocation="CenterScreen"
        Background="#0D1117"
        FontFamily="Consolas">

    <Window.Resources>
        <!-- Colors -->
        <SolidColorBrush x:Key="BgMain" Color="#0D1117"/>
        <SolidColorBrush x:Key="BgPanel" Color="#161B22"/>
        <SolidColorBrush x:Key="BgCard" Color="#1C2128"/>
        <SolidColorBrush x:Key="BgInput" Color="#21262D"/>
        <SolidColorBrush x:Key="BorderCol" Color="#30363D"/>
        <SolidColorBrush x:Key="AccentBlue" Color="#58A6FF"/>
        <SolidColorBrush x:Key="AccentGreen" Color="#3FB950"/>
        <SolidColorBrush x:Key="AccentRed" Color="#F85149"/>
        <SolidColorBrush x:Key="AccentYellow" Color="#D29922"/>
        <SolidColorBrush x:Key="TextPrimary" Color="#C9D1D9"/>
        <SolidColorBrush x:Key="TextSecondary" Color="#8B949E"/>
        <SolidColorBrush x:Key="TextMuted" Color="#484F58"/>

        <!-- TextBox Style -->
        <Style x:Key="DarkTextBox" TargetType="TextBox">
            <Setter Property="Background" Value="{StaticResource BgInput}"/>
            <Setter Property="Foreground" Value="{StaticResource TextPrimary}"/>
            <Setter Property="BorderBrush" Value="{StaticResource BorderCol}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="8,6"/>
            <Setter Property="CaretBrush" Value="{StaticResource AccentBlue}"/>
            <Setter Property="FontFamily" Value="Consolas"/>
            <Setter Property="FontSize" Value="13"/>
            <Style.Triggers>
                <Trigger Property="IsFocused" Value="True">
                    <Setter Property="BorderBrush" Value="{StaticResource AccentBlue}"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <!-- ComboBox Style -->
        <Style x:Key="DarkComboBox" TargetType="ComboBox">
            <Setter Property="Background" Value="{StaticResource BgInput}"/>
            <Setter Property="Foreground" Value="{StaticResource TextPrimary}"/>
            <Setter Property="BorderBrush" Value="{StaticResource BorderCol}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="8,5"/>
            <Setter Property="FontFamily" Value="Consolas"/>
            <Setter Property="FontSize" Value="13"/>
        </Style>

        <!-- CheckBox Style -->
        <Style x:Key="DarkCheckBox" TargetType="CheckBox">
            <Setter Property="Foreground" Value="{StaticResource TextPrimary}"/>
            <Setter Property="FontFamily" Value="Consolas"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="Margin" Value="0,3"/>
        </Style>

        <!-- Primary Button -->
        <Style x:Key="BtnPrimary" TargetType="Button">
            <Setter Property="Background" Value="#238636"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="FontFamily" Value="Consolas"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="Padding" Value="16,8"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}" CornerRadius="6"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="#2EA043"/>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter Property="Background" Value="#21262D"/>
                                <Setter Property="Foreground" Value="#484F58"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Danger Button -->
        <Style x:Key="BtnDanger" TargetType="Button" BasedOn="{StaticResource BtnPrimary}">
            <Setter Property="Background" Value="#B91C1C"/>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#DC2626"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <!-- Secondary Button -->
        <Style x:Key="BtnSecondary" TargetType="Button" BasedOn="{StaticResource BtnPrimary}">
            <Setter Property="Background" Value="#21262D"/>
            <Setter Property="Foreground" Value="{StaticResource TextPrimary}"/>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#30363D"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <!-- Slider Style -->
        <Style x:Key="DarkSlider" TargetType="Slider">
            <Setter Property="Foreground" Value="{StaticResource AccentBlue}"/>
        </Style>

        <!-- DataGrid Style -->
        <Style x:Key="DarkGrid" TargetType="DataGrid">
            <Setter Property="Background" Value="{StaticResource BgPanel}"/>
            <Setter Property="Foreground" Value="{StaticResource TextPrimary}"/>
            <Setter Property="BorderBrush" Value="{StaticResource BorderCol}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="GridLinesVisibility" Value="Horizontal"/>
            <Setter Property="HorizontalGridLinesBrush" Value="{StaticResource BorderCol}"/>
            <Setter Property="RowBackground" Value="#161B22"/>
            <Setter Property="AlternatingRowBackground" Value="#1C2128"/>
            <Setter Property="HeadersVisibility" Value="Column"/>
            <Setter Property="FontFamily" Value="Consolas"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="SelectionMode" Value="Single"/>
            <Setter Property="AutoGenerateColumns" Value="False"/>
            <Setter Property="CanUserAddRows" Value="False"/>
            <Setter Property="CanUserDeleteRows" Value="False"/>
            <Setter Property="IsReadOnly" Value="True"/>
        </Style>

        <Style TargetType="DataGridColumnHeader">
            <Setter Property="Background" Value="#0D1117"/>
            <Setter Property="Foreground" Value="{StaticResource AccentBlue}"/>
            <Setter Property="Padding" Value="8,6"/>
            <Setter Property="FontFamily" Value="Consolas"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="BorderBrush" Value="#30363D"/>
            <Setter Property="BorderThickness" Value="0,0,1,1"/>
        </Style>

        <!-- ListBox Style -->
        <Style x:Key="LogListBox" TargetType="ListBox">
            <Setter Property="Background" Value="#0D1117"/>
            <Setter Property="Foreground" Value="#3FB950"/>
            <Setter Property="FontFamily" Value="Consolas"/>
            <Setter Property="FontSize" Value="11"/>
            <Setter Property="BorderBrush" Value="{StaticResource BorderCol}"/>
            <Setter Property="BorderThickness" Value="1"/>
        </Style>

        <!-- Section Label -->
        <Style x:Key="SectionLabel" TargetType="TextBlock">
            <Setter Property="Foreground" Value="{StaticResource TextSecondary}"/>
            <Setter Property="FontSize" Value="10"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="Margin" Value="0,8,0,4"/>
        </Style>

        <!-- Stat Card -->
        <Style x:Key="StatCard" TargetType="Border">
            <Setter Property="Background" Value="{StaticResource BgCard}"/>
            <Setter Property="BorderBrush" Value="{StaticResource BorderCol}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="CornerRadius" Value="6"/>
            <Setter Property="Padding" Value="12,8"/>
        </Style>
    </Window.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="48"/>   <!-- Topbar -->
            <RowDefinition Height="*"/>    <!-- Content -->
            <RowDefinition Height="28"/>   <!-- Statusbar -->
        </Grid.RowDefinitions>

        <!-- TOPBAR -->
        <Border Grid.Row="0" Background="#010409" BorderBrush="{StaticResource BorderCol}" BorderThickness="0,0,0,1">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <!-- Logo -->
                <StackPanel Grid.Column="0" Orientation="Horizontal" Margin="16,0" VerticalAlignment="Center">
                    <TextBlock Text="⬡" Foreground="{StaticResource AccentBlue}" FontSize="22" VerticalAlignment="Center" Margin="0,0,8,0"/>
                    <TextBlock Text="PORT" Foreground="{StaticResource AccentBlue}" FontSize="18" FontWeight="Bold" VerticalAlignment="Center"/>
                    <TextBlock Text="SCOPE" Foreground="{StaticResource TextPrimary}" FontSize="18" FontWeight="Bold" VerticalAlignment="Center"/>
                </StackPanel>

                <!-- Stats Bar -->
                <StackPanel Grid.Column="1" Orientation="Horizontal" HorizontalAlignment="Center" VerticalAlignment="Center" Margin="20,0">
                    <Border Style="{StaticResource StatCard}" Margin="4,0">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="OPEN: " Foreground="{StaticResource TextSecondary}" FontSize="11"/>
                            <TextBlock Text="{Binding OpenPortCount}" Foreground="{StaticResource AccentGreen}" FontSize="13" FontWeight="Bold"/>
                        </StackPanel>
                    </Border>
                    <Border Style="{StaticResource StatCard}" Margin="4,0">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="SCANNED: " Foreground="{StaticResource TextSecondary}" FontSize="11"/>
                            <TextBlock Text="{Binding ScannedPortCount}" Foreground="{StaticResource AccentBlue}" FontSize="13" FontWeight="Bold"/>
                        </StackPanel>
                    </Border>
                    <Border Style="{StaticResource StatCard}" Margin="4,0">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="THREADS: " Foreground="{StaticResource TextSecondary}" FontSize="11"/>
                            <TextBlock Text="{Binding ThreadCount}" Foreground="{StaticResource AccentYellow}" FontSize="13" FontWeight="Bold"/>
                        </StackPanel>
                    </Border>
                </StackPanel>

                <!-- Version -->
				<TextBlock Grid.Column="2" Text="v1.0.0 // PORTSCOPE" Foreground="{StaticResource TextMuted}"
						   FontSize="10" VerticalAlignment="Center" Margin="0,0,16,0"/>
            </Grid>
        </Border>

        <!-- MAIN CONTENT -->
        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="280" MinWidth="240" MaxWidth="340"/>   <!-- Left Panel -->
                <ColumnDefinition Width="*"/>                                    <!-- Right Content -->
            </Grid.ColumnDefinitions>

            <!-- LEFT PANEL -->
            <Border Grid.Column="0" Background="{StaticResource BgPanel}"
                    BorderBrush="{StaticResource BorderCol}" BorderThickness="0,0,1,0">
                <ScrollViewer VerticalScrollBarVisibility="Auto">
                    <StackPanel Margin="14">

                        <!-- TARGET -->
                        <TextBlock Text="TARGET" Style="{StaticResource SectionLabel}"/>
                        <TextBox Style="{StaticResource DarkTextBox}"
                                 Text="{Binding TargetHost, UpdateSourceTrigger=PropertyChanged}"
                                 ToolTip="IP, hostname veya CIDR (192.168.1.0/24)"/>

                        <!-- SCAN METHOD -->
                        <TextBlock Text="SCAN METHOD" Style="{StaticResource SectionLabel}"/>
                        <ComboBox Style="{StaticResource DarkComboBox}"
                                  SelectedIndex="{Binding ScanMethodIndex}">
                            <ComboBoxItem Content="TCP Connect Scan" Tag="TCP"/>
                            <ComboBoxItem Content="SYN Scan (Admin Required)" Tag="SYN"/>
                            <ComboBoxItem Content="UDP Scan" Tag="UDP"/>
                        </ComboBox>

                        <!-- PORT RANGE -->
                        <TextBlock Text="PORT RANGE" Style="{StaticResource SectionLabel}"/>
                        <TextBox Style="{StaticResource DarkTextBox}"
                                 Text="{Binding PortRange, UpdateSourceTrigger=PropertyChanged}"
                                 ToolTip="Örnek: 1-1024 veya 80-443"/>

                        <!-- CUSTOM PORTS -->
                        <TextBlock Text="CUSTOM PORTS (comma separated)" Style="{StaticResource SectionLabel}"/>
                        <TextBox Style="{StaticResource DarkTextBox}"
                                 Text="{Binding CustomPorts, UpdateSourceTrigger=PropertyChanged}"
                                 ToolTip="Örnek: 80,443,8080,3389 (boş bırakırsan Port Range kullanılır)"/>

                        <!-- TIMEOUT -->
                        <TextBlock Style="{StaticResource SectionLabel}">
                            <Run Text="TIMEOUT: "/>
                            <Run Text="{Binding TimeoutMs}" Foreground="{StaticResource AccentBlue}"/>
                            <Run Text="ms"/>
                        </TextBlock>
                        <Slider Minimum="100" Maximum="5000" Value="{Binding TimeoutMs}"
                                Style="{StaticResource DarkSlider}" TickFrequency="100"/>

                        <!-- THREADS -->
                        <TextBlock Style="{StaticResource SectionLabel}">
                            <Run Text="THREADS: "/>
                            <Run Text="{Binding ThreadCount}" Foreground="{StaticResource AccentYellow}"/>
                        </TextBlock>
                        <Slider Minimum="10" Maximum="1000" Value="{Binding ThreadCount}"
                                Style="{StaticResource DarkSlider}" TickFrequency="10"/>

                        <!-- RETRY -->
                        <TextBlock Style="{StaticResource SectionLabel}">
                            <Run Text="RETRY COUNT: "/>
                            <Run Text="{Binding RetryCount}" Foreground="{StaticResource AccentBlue}"/>
                        </TextBlock>
                        <Slider Minimum="0" Maximum="5" Value="{Binding RetryCount}"
                                Style="{StaticResource DarkSlider}" IsSnapToTickEnabled="True" TickFrequency="1"/>

                        <!-- OPTIONS -->
                        <TextBlock Text="OPTIONS" Style="{StaticResource SectionLabel}"/>
                        <CheckBox Style="{StaticResource DarkCheckBox}"
                                  Content="Banner Grabbing"
                                  IsChecked="{Binding EnableBanner}"/>
                        <CheckBox Style="{StaticResource DarkCheckBox}"
                                  Content="OS Fingerprinting"
                                  IsChecked="{Binding EnableOsDetection}"/>
                        <CheckBox Style="{StaticResource DarkCheckBox}"
                                  Content="SSL/TLS Analysis"
                                  IsChecked="{Binding EnableSsl}"/>
                        <CheckBox Style="{StaticResource DarkCheckBox}"
                                  Content="WHOIS Lookup"
                                  IsChecked="{Binding EnableWhois}"/>

                        <!-- SCAN BUTTONS -->
                        <Button Style="{StaticResource BtnPrimary}"
                                Content="START SCAN"
                                Margin="0,12,0,4"
                                IsEnabled="{Binding CanScan}"
                                Click="BtnStartScan_Click"/>
                        <Button Style="{StaticResource BtnDanger}"
                                Content="STOP SCAN"
                                Margin="0,4"
                                IsEnabled="{Binding IsScanning}"
                                Click="BtnStopScan_Click"/>

                        <!-- PROGRESS -->
                        <ProgressBar Height="6" Margin="0,8,0,4"
                                     Value="{Binding Progress}" Maximum="100"
                                     Background="#21262D"
                                     Foreground="{StaticResource AccentGreen}"/>
                        <TextBlock Text="{Binding StatusText}"
                                   Foreground="{StaticResource TextSecondary}"
                                   FontSize="11" TextAlignment="Center"/>

                        <!-- PROFILES -->
                        <TextBlock Text="SCAN PROFILES" Style="{StaticResource SectionLabel}"/>
                        <ListBox x:Name="lstProfiles"
                                 ItemsSource="{Binding SavedProfiles}"
                                 DisplayMemberPath="Name"
                                 Background="{StaticResource BgInput}"
                                 Foreground="{StaticResource TextPrimary}"
                                 BorderBrush="{StaticResource BorderCol}"
                                 BorderThickness="1"
                                 FontFamily="Consolas"
                                 FontSize="12"
                                 MaxHeight="120"
                                 SelectionChanged="LstProfiles_SelectionChanged"/>
                        <Grid Margin="0,4">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition/>
                                <ColumnDefinition/>
                                <ColumnDefinition/>
                            </Grid.ColumnDefinitions>
                            <Button Grid.Column="0" Style="{StaticResource BtnSecondary}"
                                Content="Load" Margin="0,0,2,0" Click="BtnLoadProfile_Click"/>
                            <Button Grid.Column="1" Style="{StaticResource BtnSecondary}"
                                Content="Save" Margin="2,0,2,0" Click="BtnSaveProfile_Click"/>
                            <Button Grid.Column="2" Style="{StaticResource BtnDanger}"
                                Content="Del" Margin="2,0,0,0" Click="BtnDeleteProfile_Click"/>
                        </Grid>

                        <!-- EXPORT -->
                        <TextBlock Text="EXPORT RESULTS" Style="{StaticResource SectionLabel}"/>
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition/><ColumnDefinition/><ColumnDefinition/><ColumnDefinition/>
                            </Grid.ColumnDefinitions>
                            <Button Grid.Column="0" Style="{StaticResource BtnSecondary}" Content="JSON" Margin="1" Click="BtnExportJson_Click" FontSize="11"/>
                            <Button Grid.Column="1" Style="{StaticResource BtnSecondary}" Content="CSV" Margin="1" Click="BtnExportCsv_Click" FontSize="11"/>
                            <Button Grid.Column="2" Style="{StaticResource BtnSecondary}" Content="XML" Margin="1" Click="BtnExportXml_Click" FontSize="11"/>
                            <Button Grid.Column="3" Style="{StaticResource BtnSecondary}" Content="HTML" Margin="1" Click="BtnExportHtml_Click" FontSize="11"/>
                        </Grid>

                    </StackPanel>
                </ScrollViewer>
            </Border>

            <!-- RIGHT CONTENT -->
            <Grid Grid.Column="1">
                <Grid.RowDefinitions>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="220"/>
                </Grid.RowDefinitions>

                <!-- RESULTS TABS -->
                <TabControl Grid.Row="0" Background="{StaticResource BgMain}"
                            BorderBrush="{StaticResource BorderCol}">
                    <TabControl.Resources>
                        <Style TargetType="TabItem">
                            <Setter Property="Background" Value="{StaticResource BgPanel}"/>
                            <Setter Property="Foreground" Value="{StaticResource TextSecondary}"/>
                            <Setter Property="FontFamily" Value="Consolas"/>
                            <Setter Property="FontSize" Value="12"/>
                            <Setter Property="Padding" Value="14,8"/>
                            <Style.Triggers>
                                <Trigger Property="IsSelected" Value="True">
                                    <Setter Property="Background" Value="{StaticResource BgMain}"/>
                                    <Setter Property="Foreground" Value="{StaticResource AccentBlue}"/>
                                </Trigger>
                            </Style.Triggers>
                        </Style>
                    </TabControl.Resources>

                    <!-- OPEN PORTS TAB -->
                    <TabItem Header="Open Ports">
                        <DataGrid Style="{StaticResource DarkGrid}"
                        ItemsSource="{Binding OpenPorts}"
                        SelectedItem="{Binding SelectedPort}"
                        SelectionChanged="DgPorts_SelectionChanged"
                        HorizontalScrollBarVisibility="Auto"
                        VerticalScrollBarVisibility="Auto">
                            <DataGrid.Columns>
                                <DataGridTextColumn Header="PORT" Binding="{Binding Port}" Width="60"/>
                                <DataGridTextColumn Header="PROTO" Binding="{Binding Protocol}" Width="60"/>
                                <DataGridTextColumn Header="STATE" Binding="{Binding StateDisplay}" Width="80">
                                    <DataGridTextColumn.ElementStyle>
                                        <Style TargetType="TextBlock">
                                            <Setter Property="Foreground" Value="#3FB950"/>
                                            <Setter Property="FontWeight" Value="Bold"/>
                                        </Style>
                                    </DataGridTextColumn.ElementStyle>
                                </DataGridTextColumn>
                                <DataGridTextColumn Header="SERVICE" Binding="{Binding ServiceName}" Width="120"/>
                                <DataGridTextColumn Header="VERSION" Binding="{Binding Version}" Width="200"/>
                                <DataGridTextColumn Header="SSL" Binding="{Binding HasSsl}" Width="50"/>
                                <DataGridTextColumn Header="SSL CN" Binding="{Binding SslDetails.CommonName}" Width="150"/>
                                <DataGridTextColumn Header="SSL EXPIRY" Binding="{Binding SslDetails.ValidTo, StringFormat=yyyy-MM-dd}" Width="100"/>
                                <DataGridTextColumn Header="RESP(ms)" Binding="{Binding ResponseTimeMs}" Width="80"/>
                                <DataGridTextColumn Header="BANNER" Binding="{Binding Banner}" Width="300"/>
                            </DataGrid.Columns>
                        </DataGrid>
                    </TabItem>

                    <!-- WHOIS TAB -->
                    <TabItem Header="WHOIS / DNS">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="300"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>

                            <!-- WHOIS Summary -->
                            <StackPanel Grid.Column="0" Margin="16" >
                                <TextBlock Text="WHOIS SUMMARY" Style="{StaticResource SectionLabel}"/>
                                <Border Background="{StaticResource BgCard}" BorderBrush="{StaticResource BorderCol}"
                                        BorderThickness="1" CornerRadius="6" Padding="12">
                                    <StackPanel>
                                        <StackPanel Orientation="Horizontal" Margin="0,3">
                                            <TextBlock Text="Host: " Foreground="{StaticResource TextSecondary}" Width="90"/>
                                            <TextBlock Text="{Binding CurrentResult.TargetHost}" Foreground="{StaticResource TextPrimary}"/>
                                        </StackPanel>
                                        <StackPanel Orientation="Horizontal" Margin="0,3">
                                            <TextBlock Text="IP: " Foreground="{StaticResource TextSecondary}" Width="90"/>
                                            <TextBlock Text="{Binding CurrentResult.ResolvedIp}" Foreground="{StaticResource AccentBlue}"/>
                                        </StackPanel>
                                        <StackPanel Orientation="Horizontal" Margin="0,3">
                                            <TextBlock Text="OS Guess: " Foreground="{StaticResource TextSecondary}" Width="90"/>
                                            <TextBlock Text="{Binding CurrentResult.OsGuess}" Foreground="{StaticResource AccentYellow}"
                                                       TextWrapping="Wrap" MaxWidth="180"/>
                                        </StackPanel>
                                        <StackPanel Orientation="Horizontal" Margin="0,3">
                                            <TextBlock Text="Org: " Foreground="{StaticResource TextSecondary}" Width="90"/>
                                            <TextBlock Text="{Binding CurrentResult.WhoisData.Organization}" Foreground="{StaticResource TextPrimary}"
                                                       TextWrapping="Wrap" MaxWidth="180"/>
                                        </StackPanel>
                                        <StackPanel Orientation="Horizontal" Margin="0,3">
                                            <TextBlock Text="Country: " Foreground="{StaticResource TextSecondary}" Width="90"/>
                                            <TextBlock Text="{Binding CurrentResult.WhoisData.Country}" Foreground="{StaticResource TextPrimary}"/>
                                        </StackPanel>
                                        <StackPanel Orientation="Horizontal" Margin="0,3">
                                            <TextBlock Text="Registrar: " Foreground="{StaticResource TextSecondary}" Width="90"/>
                                            <TextBlock Text="{Binding CurrentResult.WhoisData.Registrar}" Foreground="{StaticResource TextPrimary}"
                                                       TextWrapping="Wrap" MaxWidth="180"/>
                                        </StackPanel>
                                        <StackPanel Orientation="Horizontal" Margin="0,3">
                                            <TextBlock Text="Created: " Foreground="{StaticResource TextSecondary}" Width="90"/>
                                            <TextBlock Text="{Binding CurrentResult.WhoisData.CreatedDate}" Foreground="{StaticResource TextPrimary}"/>
                                        </StackPanel>
                                        <StackPanel Orientation="Horizontal" Margin="0,3">
                                            <TextBlock Text="Expires: " Foreground="{StaticResource TextSecondary}" Width="90"/>
                                            <TextBlock Text="{Binding CurrentResult.WhoisData.ExpiryDate}" Foreground="{StaticResource AccentRed}"/>
                                        </StackPanel>
                                    </StackPanel>
                                </Border>

                                <!-- DNS lookup area -->
                                <TextBlock Text="DNS LOOKUP" Style="{StaticResource SectionLabel}" Margin="0,16,0,4"/>
                                <StackPanel Orientation="Horizontal">
                                    <TextBox x:Name="TxtDnsLookup" Style="{StaticResource DarkTextBox}"
                                             Width="180" Margin="0,0,6,0"/>
                                    <Button Style="{StaticResource BtnSecondary}" Content="Lookup"
                                            Click="BtnDnsLookup_Click" Padding="10,6"/>
                                </StackPanel>
                                <TextBox x:Name="TxtDnsResult" Style="{StaticResource DarkTextBox}"
                                         Margin="0,6,0,0" Height="80" IsReadOnly="True"
                                         TextWrapping="Wrap" VerticalScrollBarVisibility="Auto"/>
                            </StackPanel>

                            <!-- Raw WHOIS -->
                            <Grid Grid.Column="1" Margin="0,16,16,16">
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="*"/>
                                </Grid.RowDefinitions>
                                <TextBlock Text="RAW WHOIS DATA" Style="{StaticResource SectionLabel}"/>
                                <TextBox Grid.Row="1" Style="{StaticResource DarkTextBox}"
                                         Text="{Binding CurrentResult.WhoisData.RawData}"
                                         IsReadOnly="True" TextWrapping="Wrap"
                                         VerticalScrollBarVisibility="Auto"
                                         FontSize="11"/>
                            </Grid>
                        </Grid>
                    </TabItem>

                    <!-- SSL TAB -->
                    <TabItem Header="SSL/TLS">
                        <DataGrid Style="{StaticResource DarkGrid}"
                                  x:Name="DgSsl"
                                  ItemsSource="{Binding SslPorts}">
                            <DataGrid.Columns>
                                <DataGridTextColumn Header="PORT" Binding="{Binding Port}" Width="60"/>
                                <DataGridTextColumn Header="COMMON NAME" Binding="{Binding SslDetails.CommonName}" Width="200"/>
                                <DataGridTextColumn Header="ISSUER" Binding="{Binding SslDetails.Issuer}" Width="200"/>
                                <DataGridTextColumn Header="VALID FROM" Binding="{Binding SslDetails.ValidFrom, StringFormat=yyyy-MM-dd}" Width="110"/>
                                <DataGridTextColumn Header="VALID TO" Binding="{Binding SslDetails.ValidTo, StringFormat=yyyy-MM-dd}" Width="110"/>
                                <DataGridTextColumn Header="EXPIRED" Binding="{Binding SslDetails.IsExpired}" Width="70"/>
                                <DataGridTextColumn Header="DAYS LEFT" Binding="{Binding SslDetails.DaysUntilExpiry}" Width="90"/>
                                <DataGridTextColumn Header="ALGORITHM" Binding="{Binding SslDetails.SignatureAlgorithm}" Width="*"/>
                            </DataGrid.Columns>
                        </DataGrid>
                    </TabItem>

                    <!-- SCAN HISTORY TAB -->
                    <TabItem Header="History">
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="*"/>
                            </Grid.RowDefinitions>

                            <!-- Toolbar -->
                            <Border Grid.Row="0" Background="#161B22" BorderBrush="#30363D" BorderThickness="0,0,0,1" Padding="8,4">
                                <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                                    <Button Content="Seçili Sil" Style="{StaticResource BtnDanger}"
                        Padding="10,4" FontSize="11" Margin="0,0,6,0"
                        Click="BtnDeleteHistory_Click"/>
                                    <Button Content="Tümünü Sil" Style="{StaticResource BtnDanger}"
                        Padding="10,4" FontSize="11"
                        Click="BtnClearHistory_Click"/>
                                </StackPanel>
                            </Border>

                            <DataGrid Grid.Row="1" Style="{StaticResource DarkGrid}"
                  x:Name="DgHistory"
                  ItemsSource="{Binding ScanHistory}">
                                <DataGrid.Columns>
                                    <DataGridTextColumn Header="TARGET" Binding="{Binding TargetHost}" Width="150"/>
                                    <DataGridTextColumn Header="IP" Binding="{Binding ResolvedIp}" Width="120"/>
                                    <DataGridTextColumn Header="METHOD" Binding="{Binding ScanMethod}" Width="80"/>
                                    <DataGridTextColumn Header="OPEN" Binding="{Binding OpenPortCount}" Width="60"/>
                                    <DataGridTextColumn Header="OS GUESS" Binding="{Binding OsGuess}" Width="250"/>
                                    <DataGridTextColumn Header="DURATION" Binding="{Binding Duration}" Width="100"/>
                                    <DataGridTextColumn Header="STARTED" Binding="{Binding ScanStarted, StringFormat=HH:mm:ss}" Width="80"/>
                                </DataGrid.Columns>
                            </DataGrid>
                        </Grid>
                    </TabItem>

                </TabControl>

                <!-- LOG PANEL -->
                <Border Grid.Row="1" Background="{StaticResource BgPanel}"
                        BorderBrush="{StaticResource BorderCol}" BorderThickness="0,1,0,0">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="28"/>
                            <RowDefinition Height="*"/>
                        </Grid.RowDefinitions>

                        <!-- Log Header -->
                        <Border Grid.Row="0" Background="#010409" BorderBrush="{StaticResource BorderCol}" BorderThickness="0,0,0,1">
                            <Grid>
                                <TextBlock Text="TERMINAL OUTPUT" Foreground="{StaticResource AccentGreen}"
                                           FontSize="11" FontWeight="Bold"
                                           VerticalAlignment="Center" Margin="12,0"/>
                                <Button Content="Clear" Style="{StaticResource BtnSecondary}"
                                        HorizontalAlignment="Right" Margin="0,2,8,2"
                                        Padding="8,2" FontSize="10" Click="BtnClearLog_Click"/>
                            </Grid>
                        </Border>

                        <ListBox Grid.Row="1" Style="{StaticResource LogListBox}"
                                 ItemsSource="{Binding Logs}"
                                 BorderThickness="0">
                            <ListBox.ItemTemplate>
                                <DataTemplate>
                                    <TextBlock Text="{Binding}" FontSize="11" Padding="2,1"/>
                                </DataTemplate>
                            </ListBox.ItemTemplate>
                        </ListBox>
                    </Grid>
                </Border>
            </Grid>
        </Grid>

        <!-- STATUS BAR -->
        <Border Grid.Row="2" Background="#010409" BorderBrush="{StaticResource BorderCol}" BorderThickness="0,1,0,0">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <TextBlock Grid.Column="0" Text="{Binding ScanStats}"
                           Foreground="{StaticResource TextSecondary}" FontSize="10"
                           VerticalAlignment="Center" Margin="12,0"/>
                <TextBlock Grid.Column="1" x:Name="TxtClock"
                           Foreground="{StaticResource TextMuted}" FontSize="10"
                           VerticalAlignment="Center" Margin="0,0,12,0"/>
                <TextBlock Grid.Column="2" Text="PortScope // Windows Port Scanner"
                           Foreground="{StaticResource TextMuted}" FontSize="10"
                           VerticalAlignment="Center" Margin="0,0,12,0"/>
            </Grid>
        </Border>
    </Grid>
</Window>
